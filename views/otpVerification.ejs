<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OTP Verification</title>
</head>
<body>
    <p>A 6-digit OTP is sent to your e-mail: <%= userEmail %>. Please enter it and verify the OTP</p>
    <form action="/users/otp" method="post">
        <input type="text" name="otp" id="otp" required autocomplete="off" placeholder="Enter the OTP" maxlength="6" pattern="\d{6}">
        <input type="hidden" name="email" value="<%= userEmail %>">
        <button type="submit">Verify OTP</button>
    </form>
</body>
</html>
